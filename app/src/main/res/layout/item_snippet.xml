<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Category color bar (left side) -->
        <View
            android:id="@+id/viewCategoryBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="60dp"
            android:background="@color/purple_500"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header row: title + pin + checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#212121"/>

                <ImageView
                    android:id="@+id/ivPin"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="6dp"
                    android:src="@drawable/ic_pin"
                    android:tint="@color/primary"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/ivCheck"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle"
                    android:tint="@color/primary"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

            <!-- Code preview -->
            <TextView
                android:id="@+id/tvCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="code..."
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="8dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:background="@drawable/bg_code_preview"
                android:padding="8dp"
                android:textColor="#757575"/>

            <!-- Footer: category + tags + buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖥️ Bash"
                    android:textSize="11sp"
                    android:textColor="@color/primary"
                    android:background="@drawable/bg_category_chip"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"/>

                <TextView
                    android:id="@+id/tvTags"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="#bash #git"
                    android:textSize="11sp"
                    android:textColor="@color/primary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="monospace"/>

                <ImageButton
                    android:id="@+id/btnCopy"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_copy"
                    android:contentDescription="Copy code"
                    android:tint="@color/primary"/>

                <ImageButton
                    android:id="@+id/btnMore"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_more_vert"
                    android:contentDescription="More options"
                    android:tint="#757575"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
